// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output = "./generated/prisma"
 
}

datasource db {
  provider = "mysql"

}

model User {
  id                      Int              @id @default(autoincrement())
  email                   String           @unique
  password                String
  name                    String
  role                    Role             @default(USER)
  address                 String?
  phone                   String?
  Preferences             Preferences?
  ingredients             Ingredient[]
  favoriteRecipe          FavoriteRecipe[]
  nutritionProfile        NutritionProfile?
  mealPlans               MealPlan[]
  products                Product[]
  conversationsAsUser     Conversation[] @relation("UserConversations")
  conversationsAsNutritionist Conversation[] @relation("NutritionistConversations")
}

enum Role{
  USER
  FARMER
  NUTRITIONIST
}

  model Preferences {
  id         Int     @id @default(autoincrement())
  userId     Int     @unique
  allergies  String?
  dislikes   String?
  conditions String?
  user       User    @relation(fields: [userId], references: [id])
}

model Ingredient {
  id         Int    @id @default(autoincrement())
  name       String
  quantity   Float
  unit       String
  category   String
  expiresAt  DateTime
  userId     Int
  user       User   @relation(fields: [userId], references:[id])
}

model FavoriteRecipe {
  id        Int     @id @default(autoincrement())
  recipeId  Int
  title     String
  image     String
  userId    Int
  user      User    @relation(fields: [userId], references: [id])
}


model NutritionProfile {
  id              Int     @id @default(autoincrement())
  userId          Int     @unique
  weight          Float
  height          Float
  age             Int
  gender          String
  activityLevel   String
  goal            String
  user            User    @relation(fields: [userId], references: [id])
}


model MealPlan{
  id              Int     @id @default(autoincrement())
  date            DateTime
  mealType        String // "breakfast" | "lunch" | "dinner"
  calories        Int
  recipeId        Int
  title           String
  protein         Int       @default(0)
  carbs           Int       @default(0)
  fat             Int       @default(0)
  userId          Int
  user            User    @relation(fields:[userId], references:[id])
}

model Product{
  id              Int     @id @default(autoincrement())
  name            String
  price           Float
  quantity        Int
  category        String
  createdAt       DateTime  @default(now())
  farmerId          Int
  farmer            User    @relation(fields:[farmerId], references:[id])
}

model Conversation{
  id              Int       @id @default(autoincrement())
  userId          Int
  nutritionistId  Int
  createdAt       DateTime  @default(now())
  message         Message[]
  user            User    @relation("UserConversations",fields:[userId], references:[id])
  nutritionist    User    @relation("NutritionistConversations",fields:[nutritionistId], references:[id])
}

model Message{
  id             Int      @id @default(autoincrement())
  content        String
  senderRole     Role
  createdAt      DateTime @default(now())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}
